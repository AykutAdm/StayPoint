@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body>
    <div class="container-fluid bg-white p-0">

        @await Component.InvokeAsync("_DefaultSpinnerComponentPartial")

        @await Component.InvokeAsync("_DefaultNavbarComponentPartial")

        @await Component.InvokeAsync("_DefaultSliderComponentPartial")

        @await Component.InvokeAsync("_DefaultAboutUsComponentPartial")

        @await Component.InvokeAsync("_DefaultOurRoomsComponentPartial")

        @await Component.InvokeAsync("_DefaultTrailerComponentPartial")

        @await Component.InvokeAsync("_DefaultServiceComponentPartial")

        @await Component.InvokeAsync("_DefaultTestimonialComponentPartial")

        @await Component.InvokeAsync("_DefaultTeamComponentPartial")

        @await Html.PartialAsync("_SubscribePartial")

        @await Component.InvokeAsync("_DefaultFooterComponentPartial")

        <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>
    @await Component.InvokeAsync("_DefaultScriptsComponentPartial")
</body>
</html>
