@model CreateStaffDto
@{
    ViewData["Title"] = "CreateStaff";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<form method="post">
    <label>Personel Adı</label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />
    <label>Personel Ünvanı</label>
    <input type="text" asp-for="Title" class="form-control" />
    <br />
    <label>Instagram</label>
    <input type="text" asp-for="InstagramUrl" class="form-control" />
    <br />
    <label>Twitter</label>
    <input type="text" asp-for="TwitterUrl" class="form-control" />
    <br />
    <label>Facebook</label>
    <input type="text" asp-for="FacebookUrl" class="form-control" />
    <br />
    <button class="btn btn-primary">Personeli Ekle</button>
</form>

