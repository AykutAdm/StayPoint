@model UpdateTestimonialDto
@{
    ViewData["Title"] = "UpdateTestimonial";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<form method="post">
    <input type="hidden" asp-for="TestimonialId" />
    <label>Referans Adı</label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />
    <label>Referans Ünvanı</label>
    <input type="text" asp-for="Title" class="form-control" />
    <br />
    <label>Referans Görsel</label>
    <input type="text" asp-for="ImageUrl" class="form-control" />
    <br />
    <label>Açıklama</label>
    <textarea class="form-control" asp-for="Description" rows="5"></textarea>
    <button class="btn btn-primary">Referans Güncelle</button>
</form>


